<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kr.ac.tukorea.springProject.repository.MemberMapper">
<select
    id="loginCheck"
    resultType="_int"
    parameterType="kr.ac.tukorea.springProject.dto.UserDTO"
>
		SELECT
			count(*) as cnt
		FROM tbl_member
		WHERE
			id = #{id}
			AND
			pwd = #{pwd};
	</select>
	
	<select
		id="memberList"
		resultType="kr.ac.tukorea.springProject.dto.UserDTO"
	>
		SELECT * FROM tbl_member;	
	</select>
	
	<!--
	<update></update>
	
	<insert></insert>
	
	<delete></delete>
	-->
</mapper>